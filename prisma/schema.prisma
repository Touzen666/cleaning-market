generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Post {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  title       String
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([title])
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                   String               @id @default(cuid())
  name                 String?
  email                String?              @unique
  emailVerified        DateTime?
  image                String?
  type                 UserType             @default(UNKNOWN)
  accounts             Account[]
  createdOwners        ApartmentOwner[]     @relation("AdminCreatedOwners")
  assignedOwnerships   ApartmentOwnership[] @relation("AdminAssignedOwnerships")
  approvedReports      MonthlyReport[]      @relation("AdminApprovedReports")
  createdReports       MonthlyReport[]      @relation("AdminCreatedReports")
  createdOwnerNotes    OwnerNote[]          @relation("AdminCreatedNotes")
  posts                Post[]
  reportHistoryActions ReportHistory[]      @relation("AdminReportHistory")
  sessions             Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Reservation {
  source         String
  createDate     DateTime     @db.Date
  guest          String
  start          DateTime
  end            DateTime
  apartmentName  String
  address        String
  status         String
  payment        String
  paymantValue   Float
  currency       String
  adults         Int?
  children       Int?
  importSource   String?
  importBatchId  String?
  id             Int          @id @default(autoincrement())
  apartmentId    Int?
  idobookingId   Int?         @unique
  rateCorrection Float?
  checkInCards   CheckInCard?
  reportItems    ReportItem[]
  apartment      Apartment?   @relation(fields: [apartmentId], references: [id])
}

model Apartment {
  name                   String               @unique
  slug                   String               @unique
  address                String
  defaultRentAmount      Float?               @default(0)
  defaultUtilitiesAmount Float?               @default(0)
  hasBalcony             Boolean              @default(false)
  hasParking             Boolean              @default(false)
  maxGuests              Int?                 @default(4)
  cleaningCosts          Json?                // Koszty sprzątania dla różnych liczby gości {1: 50, 2: 80, 3: 100, ...}
  importSource           String?
  importBatchId          String?
  id                     Int                  @id @default(autoincrement())
  idobookingId           Int?                 @unique
  images                 ApartmentImage[]
  ownerships             ApartmentOwnership[]
  leadApplications       LeadApplication[]
  monthlyReports         MonthlyReport[]
  reservations           Reservation[]
  averageRating          Float?               @default(0)
}

model ApartmentImage {
  id          String    @id @default(uuid())
  url         String
  alt         String?
  isPrimary   Boolean   @default(false)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  apartmentId Int
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@index([apartmentId])
}

model LeadApplication {
  id          String     @id @default(uuid())
  name        String
  surname     String
  phone       String
  email       String
  message     String?
  createdAt   DateTime   @default(now())
  apartmentId Int?
  apartment   Apartment? @relation(fields: [apartmentId], references: [id])
}

model CheckInCard {
  id                           String         @id @default(uuid())
  createdAt                    DateTime       @default(now())
  updatedAt                    DateTime       @updatedAt
  firstName                    String
  lastName                     String
  dateOfBirth                  DateTime       @db.Date
  nationality                  String
  documentType                 String
  documentNumber               String
  bookingHolderFirstName       String?
  bookingHolderLastName        String?
  isDifferentGuest             Boolean        @default(false)
  addressStreet                String
  addressCity                  String
  addressZipCode               String
  addressCountry               String
  submittedApartmentIdentifier String
  checkInDate                  DateTime       @db.Date
  isPrimaryGuest               Boolean
  actualCheckInTime            DateTime?
  reservationId                Int?           @unique
  reservation                  Reservation?   @relation(fields: [reservationId], references: [id])
  guestSessions                GuestSession[]
}

model GuestSession {
  id            String      @id @default(uuid())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  expiresAt     DateTime
  lastActivity  DateTime    @default(now())
  apartmentSlug String
  isActive      Boolean     @default(true)
  checkInCardId String
  checkInCard   CheckInCard @relation(fields: [checkInCardId], references: [id], onDelete: Cascade)

  @@index([apartmentSlug, isActive])
  @@index([expiresAt])
}

model ApartmentOwner {
  id                          String               @id @default(uuid())
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  email                       String               @unique
  firstName                   String
  lastName                    String
  phone                       String?
  companyName                 String?
  nip                         String?
  address                     String?
  city                        String?
  postalCode                  String?
  profileImageUrl             String?
  passwordHash                String?
  temporaryPassword           String?
  temporaryPasswordExpiresAt  DateTime?
  isFirstLogin                Boolean              @default(true)
  paymentType                 PaymentType          @default(COMMISSION)
  fixedPaymentAmount          Decimal?
  vatOption                   VATOption            @default(NO_VAT)
  isActive                    Boolean              @default(true)
  lastLoginAt                 DateTime?
  createdByAdminId            String
  resetPasswordToken          String?
  resetPasswordTokenExpiresAt DateTime?
  createdByAdmin              User                 @relation("AdminCreatedOwners", fields: [createdByAdminId], references: [id])
  ownedApartments             ApartmentOwnership[]
  monthlyReports              MonthlyReport[]
  notes                       OwnerNote[]

  @@index([email])
  @@index([isActive])
}

model ApartmentOwnership {
  id                String         @id @default(uuid())
  createdAt         DateTime       @default(now())
  ownerId           String
  isActive          Boolean        @default(true)
  assignedAt        DateTime       @default(now())
  assignedByAdminId String
  apartmentId       Int
  apartment         Apartment      @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  assignedByAdmin   User           @relation("AdminAssignedOwnerships", fields: [assignedByAdminId], references: [id])
  owner             ApartmentOwner @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, apartmentId])
  @@index([ownerId, isActive])
  @@index([apartmentId, isActive])
}

model AdditionalDeduction {
  id        String        @id @default(uuid())
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  reportId  String
  name      String
  amount    Float
  vatOption VATOption     @default(NO_VAT)
  order     Int           @default(0)
  report    MonthlyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

model MonthlyReport {
  id                   String                @id @default(uuid())
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  year                 Int
  month                Int
  ownerId              String
  createdByAdminId     String
  status               ReportStatus          @default(DRAFT)
  draftNotes           String?
  approvedAt           DateTime?
  approvedByAdminId    String?
  sentAt               DateTime?
  totalRevenue         Float                 @default(0)
  totalExpenses        Float                 @default(0)
  netIncome            Float                 @default(0)
  ownerPayoutAmount    Float                 @default(0)
  currency             String                @default("PLN")
  rentAmount           Float?                @default(0)
  utilitiesAmount      Float?                @default(0)
  suggestedRent        Float?                @default(0)
  suggestedUtilities   Float?                @default(0)
  finalSettlementType  SettlementType?
  finalOwnerPayout     Float?
  finalHostPayout      Float?
  finalIncomeTax       Float?
  finalVatAmount       Float?
  adminCommissionAmount Float?
  afterCommission      Float?
  afterRentAndUtilities Float?
  totalAdditionalDeductions Float?
  apartmentId          Int
  additionalDeductions AdditionalDeduction[]
  apartment            Apartment             @relation(fields: [apartmentId], references: [id])
  approvedByAdmin      User?                 @relation("AdminApprovedReports", fields: [approvedByAdminId], references: [id])
  createdByAdmin       User                  @relation("AdminCreatedReports", fields: [createdByAdminId], references: [id])
  owner                ApartmentOwner        @relation(fields: [ownerId], references: [id])
  history              ReportHistory[]
  items                ReportItem[]

  @@unique([apartmentId, year, month])
  @@index([status])
  @@index([ownerId, status])
}

model ReportItem {
  id              String             @id @default(uuid())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  reportId        String
  type            ReportItemType
  category        String
  description     String
  amount          Float
  currency        String             @default("PLN")
  expenseCategory ExpenseCategory?
  portal          ReservationPortal?
  date            DateTime           @db.Date
  notes           String?
  isAutoGenerated Boolean            @default(false)
  reservationId   Int?
  report          MonthlyReport      @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reservation     Reservation?       @relation(fields: [reservationId], references: [id])

  @@index([reportId, type])
}

model ReportHistory {
  id             String        @id @default(uuid())
  createdAt      DateTime      @default(now())
  reportId       String
  adminId        String
  action         String
  previousStatus ReportStatus?
  newStatus      ReportStatus?
  notes          String?
  admin          User          @relation("AdminReportHistory", fields: [adminId], references: [id])
  report         MonthlyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
}

model OwnerNote {
  id               String         @id @default(uuid())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  ownerId          String
  createdByAdminId String
  type             NoteType
  title            String
  content          String
  isImportant      Boolean        @default(false)
  createdByAdmin   User           @relation("AdminCreatedNotes", fields: [createdByAdminId], references: [id])
  owner            ApartmentOwner @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, type])
  @@index([ownerId, isImportant])
  @@index([createdAt])
}

enum UserType {
  ADMIN
  UNKNOWN
  GUEST
  OWNER
  CLEANER
}

enum PaymentType {
  COMMISSION
  FIXED_AMOUNT
}

enum VATOption {
  NO_VAT
  VAT_8
  VAT_23
}

enum ReportStatus {
  DRAFT
  REVIEW
  APPROVED
  SENT
}

enum SettlementType {
  COMMISSION
  FIXED
  FIXED_MINUS_UTILITIES
}

enum ReportItemType {
  REVENUE
  EXPENSE
  FEE
  TAX
  COMMISSION
}

enum ExpenseCategory {
  CZYNSZ
  MEDIA
  PRAD
  GAZ
  WODA
  INTERNET
  PRANIE
  SPRZATANIE
  SRODKI_CZYSTOSCI
  TEKSTYLIA
}

enum ReservationPortal {
  BOOKING
  AIRBNB
  IDOBOOKING
  CHANEL_MANAGER
}

enum NoteType {
  GENERAL
  PAYMENT
  COMMUNICATION
  ISSUE
  REMINDER
  IMPORTANT
}
